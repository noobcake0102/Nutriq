# Copy this file to fastlane/.env and fill in the values.
# fastlane/.env is gitignored — never commit real keys.
#
# All four come from App Store Connect → Users and Access → Integrations →
# App Store Connect API (https://appstoreconnect.apple.com/access/integrations/api).

# The Key ID shown next to the key you generated (e.g. "2X9ABC1234").
ASC_KEY_ID=

# The Issuer ID shown at the top of the Integrations page (a UUID).
ASC_ISSUER_ID=

# Absolute path to the downloaded private key file (AuthKey_XXXXXXXXXX.p8).
# Apple lets you download it ONCE — store it outside the repo, e.g.:
#   /Users/you/.appstoreconnect/private/AuthKey_2X9ABC1234.p8
ASC_KEY_PATH=

# Your Apple Developer Team ID (10 chars). Find it at
# https://developer.apple.com/account → Membership → Team ID.
ASC_TEAM_ID=
